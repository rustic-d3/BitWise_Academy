{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES6", "DOM"],
    "types": ["cypress"],
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../node_modules/cypress/types",
    "support/index.d.ts"
  ]
}
